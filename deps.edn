{:paths ["src" "resources"]
 ;; kasane.json/kasane.svg/kasane.gltf は既存 kotoba-lang repo への薄い
 ;; adapter（2026-07-08、独自実装は廃止）。org-khronos-glb は kasane.gltf より
 ;; 高機能なGLB reader/writerを既に独立に持っていた（accessor decode含む）。
 ;; ooxml/office: ooxml->doc のformat検出+multi-part discovery+Word text抽出
 ;; に使う（両方とも100%移植可能な関数のみ呼ぶ — office.opc/open-package
 ;; というJVM専用関数(java.util.zip)は一切呼ばない。kasane.normalizeの
 ;; docstring参照）。
 :deps  {io.github.kotoba-lang/json           {:git/sha "1e77c42dd044610cfb3eb12e2831eec4b3fdb5a6"}
         io.github.kotoba-lang/org-w3-svg     {:git/sha "516e6f45cae4a802a2f84766a71f62f91e5d1a98"}
         io.github.kotoba-lang/org-khronos-glb {:git/sha "87c6cced3e75616c3b9b92e3e0f6c64f228e2887"}
         io.github.kotoba-lang/ooxml          {:git/sha "0bc223380c1a582cfd7b7b829b0492d84d128fc4"}
         io.github.kotoba-lang/office         {:git/sha "b5838def811d05f1db1e7d77e5daede8ac953883"}}
 :aliases
 {;; malli はモデル検証(SSoT)用。WASM/コア経路には含めない。
  :malli {:extra-deps {metosin/malli {:mvn/version "0.16.4"}}}
  ;; テスト(JVM)。ooxml_test/inflate_test 系だけ fixture 生成に java.util.zip
  ;; を使う（ライブラリ本体は使わない）。zip.core(org-pkware-zip) はテスト専用
  ;; の entries 供給源（ooxml_test.clj: 実際の呼び出し側は zip.core で unzip
  ;; した entries を kasane.normalize/ooxml->doc に渡す想定）。
  :test  {:extra-paths ["test"]
          :extra-deps  {io.github.cognitect-labs/test-runner
                        {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                        io.github.kotoba-lang/org-pkware-zip
                        {:git/sha "35d7dfd37d59ed8b8e99964676aeb2375e0c46b3"}}
          :main-opts   ["-m" "cognitect.test-runner"]}}}
